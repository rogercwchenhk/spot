# ============================================================
# 客户雷达 — 环境变量模板
# 复制为 .env 后填入真实值
# ============================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- 知了标讯 API ---
ZLBX_API_KEY=

# --- 小米 mimo AI Pipeline ---
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# --- 企业微信机器人 ---
WECOM_WEBHOOK_URL=

# --- Supabase Direct Connection ---
DATABASE_URL=

# --- 初始管理员账号 ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Resend 邮件服务 ---
RESEND_API_KEY=
EMAIL_FROM=noreply@leadcom.chat

# --- SMTP 邮件服务 ---
SMTP_HOST=smtp.yunyou.top
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@leadcom.chat

# --- 安全配置 ---
# CORS 白名单（逗号分隔多个域名，留空则允许所有）
CORS_ORIGIN=
# 日志级别 (trace/debug/info/warn/error/fatal)
LOG_LEVEL=info
# 服务端口
PORT=3200
# 前端地址（用于密码重置跳转）
APP_URL=http://localhost:5173
